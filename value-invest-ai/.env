# ValueInvestAI Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string (asyncpg driver for async support)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://valueinvest:valueinvest_dev_password@localhost:5432/valueinvestai

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=valueinvest
POSTGRES_PASSWORD=valueinvest_dev_password
POSTGRES_DB=valueinvestai

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# EOD Historical Data API (primary data source)
# Get your key at: https://eodhistoricaldata.com/
EOD_API_KEY= 695bff490867e4.85621147

# Financial Modeling Prep API (optional, secondary data source)
# Get your key at: https://financialmodelingprep.com/
FMP_API_KEY=ERcFMoP5yaix9JHe1Ei6uYbNua3JRzLH

# =============================================================================
# AI CONFIGURATION
# =============================================================================

# Google Gemini API Key for Buffett AI analysis
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
APP_ENV=development

# Enable debug mode (verbose logging, detailed errors)
DEBUG=true

# Secret key for security (change in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production-use-secrets-token

# =============================================================================
# API SETTINGS
# =============================================================================

# API version prefix
API_V1_PREFIX=/api/v1

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================

# Backend API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# =============================================================================
# RATE LIMITING & CACHING
# =============================================================================

# API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Cache TTL for financial data (seconds)
CACHE_TTL_FINANCIALS=3600

# Cache TTL for stock prices (seconds)
CACHE_TTL_PRICES=300
